# ---- REQUIRED ----
PAY_TO_WALLET=0xYOUR_BASE_WALLET_HERE

# OPTIONAL multi-chain: a Solana address enables /sol/* routes (USDC on Solana).
# Solana settlement REQUIRES the CDP API keys below to be set.
SOLANA_PAY_TO=

# ---- OPTIONAL DATA ----
# Engine uses Yahoo Finance (free, no key) for price + history. Finnhub is an
# optional live-quote override only; leave blank to run key-free.
FINNHUB_KEY=

# ---- FACILITATOR ----
USE_TESTNET=false           # false = mainnet (CDP). true = signup-free x402.org / Base Sepolia.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ---- RESPONSE SIGNING (ed25519, verifiable trust) ----
# Generate once:  node sign.js --gen   then paste the private (base64) here.
RESPONSE_SIGNING_KEY=

# ---- LOYALTY LEDGER (durable, free) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TOKEN_SECRET=               # HMAC secret for bearer token signing. Auto-generated by Render.

# ---- REFERRAL (free-call credits) ----
REF_REFERRER_BONUS=10
REF_REFEREE_WELCOME=5

# ---- AFFILIATE (USDC revenue-share) ----
AFFILIATE_RATE=0.30

# ---- PAYOUT SCRIPT (payout.js; run manually or on cron) ----
VENDOR_PRIVATE_KEY=         # wallet holding USDC on Base, used to pay affiliates
RPC_URL=https://mainnet.base.org
MIN_PAYOUT_USD=1

# ---- TRADINGVIEW WEBHOOK SECURITY ----
# Optional secret to gate the /webhook/tv and /api/tv/:feed/webhook endpoints.
# TradingView alerts must include header X-Webhook-Secret: <this value>.
TV_WEBHOOK_SECRET=

# ---- DISCORD NOTIFICATIONS ----
# Webhook URL for Matrix snap alerts. Leave blank to disable Discord posting.
DISCORD_WEBHOOK=

# ---- AP2 (Google Agent Payments Protocol) ----
# "off" | "optional" (default) | "required"
AP2_MODE=optional
# JSON object mapping key IDs to PEM public keys for trusted AP2 mandate issuers.
AP2_TRUSTED_ISSUERS={}
