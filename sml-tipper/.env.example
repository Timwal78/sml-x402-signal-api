# === X.com / Twitter API ===
# Get these from developer.twitter.com → your app → Keys and Tokens
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
# Your bot's Twitter username (without @)
TWITTER_BOT_USERNAME=TipMasterX
# Your bot's numeric Twitter user ID (find via tweeterid.com)
TWITTER_BOT_USER_ID=

# === XRPL mainnet (RLUSD + XRP) ===
XRPL_SEED=sYOUR_FAMILY_SEED
XRPL_ADDRESS=rYOUR_XRPL_ADDRESS
XRPL_NODE=wss://xrplcluster.com
# RLUSD issuer address on mainnet
RLUSD_ISSUER=rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De

# === Xahau (XAH) — defaults to same seed/address as XRPL if not set ===
XAH_SEED=
XAH_ADDRESS=
XAH_NODE=wss://xahau.network

# === Fee Cuts (both paid by users, forwarded to your treasury wallets) ===
# Cut 1: taken from every deposit before crediting user balance
DEPOSIT_FEE_PCT=0.01
# Cut 2: taken from every tip / split / airdrop send
TIP_FEE_PCT=0.03
# Your treasury wallets (leave blank to skip forwarding)
FEE_WALLET_XRPL=rYOUR_FEE_WALLET_XRPL
FEE_WALLET_XAHAU=rYOUR_FEE_WALLET_XAHAU

# === Default currency when none specified ===
DEFAULT_TIP_CURRENCY=RLUSD

# === Tip Limits ===
MIN_TIP=0.01
MAX_TIP=1000

# === App ===
PORT=3000
# How often to poll for mentions (ms). 15000 = 15s stays safely under rate limits.
POLL_INTERVAL_MS=15000
DB_PATH=./data/registry.db
